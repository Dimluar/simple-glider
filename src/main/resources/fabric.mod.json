{
	"schemaVersion": 1,
	"id": "simpleglider",
	"version": "${version}",
	"name": "Simple Glider",
	"description": "This mods add gliders to minecraft.",
	"authors": [
		"Dimluar"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/simpleglider/icon.png",
	"environment": "*",
